{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lumi-vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LUMI vLLM",
      "options": {
        "baseURL": "http://host.docker.internal:8042/v1",
        "apiKey": "<YOUR_GENERATED_API_KEY>"
      },
      "models": {
        "Qwen/Qwen3-Coder-Next": {
          "name": "Qwen3-Coder",
          "limit": {
            "context": 150000,
            "output": 50000
          }
        }
      }
    }
  },
  "model": "lumi-vllm/Qwen/Qwen3-Coder-Next"
}
